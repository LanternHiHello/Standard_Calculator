<Window x:Class="Calculator.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Calculator"
        Foreground="#000000"
        Icon="avares://StullerCalc/Assets/calculator.ico"
        Width="560" Height="620"
        MinWidth="300" MinHeight="500"
        Title="Stuller Official Calculator">

    
    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#D0D0D0"/>
        </Style>
    </Window.Styles>

    <Grid Background="White" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <Border Grid.Row="0" Grid.ColumnSpan="4" BorderBrush="#FF808080" BorderThickness="1.5" CornerRadius="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="{Binding ExpressionText}"
                           Foreground="#AAAAAA" FontSize="16"
                           HorizontalAlignment="Right" Margin="10,6,10,0"/>
                <Viewbox Grid.Row="1" Stretch="Uniform" HorizontalAlignment="Right" Margin="10,4,10,8">
                    <TextBlock Text="{Binding DisplayText}" FontSize="34"/>
                </Viewbox>
            </Grid>
        </Border>

 
        <Button Grid.Row="2" Grid.Column="0" Content="%" Command="{Binding PercentageCommand}"/>
        <Button Grid.Row="2" Grid.Column="1" Content="CE" Command="{Binding ClearEntryCommand}"/>
        <Button Grid.Row="2" Grid.Column="2" Content="C" Command="{Binding ClearCommand}"/>
        <Button Grid.Row="2" Grid.Column="3" Content="⌫" Command="{Binding DeleteCommand}"/>

        <Button Grid.Row="3" Grid.Column="0" Content="⅟x" Command="{Binding ReciprocalCommand}"/>
        <Button Grid.Row="3" Grid.Column="1" Content="x²" Command="{Binding ExponentCommand}"/>
        <Button Grid.Row="3" Grid.Column="2" Content="√x" Command="{Binding SquareRootCommand}"/>
        <Button Grid.Row="3" Grid.Column="3" Content="÷" Command="{Binding DivideCommand}"/>

        <Button Grid.Row="4" Grid.Column="0" Content="7" Command="{Binding AppendDigitCommand}" CommandParameter="7"/>
        <Button Grid.Row="4" Grid.Column="1" Content="8" Command="{Binding AppendDigitCommand}" CommandParameter="8"/>
        <Button Grid.Row="4" Grid.Column="2" Content="9" Command="{Binding AppendDigitCommand}" CommandParameter="9"/>
        <Button Grid.Row="4" Grid.Column="3" Content="x" Command="{Binding MultiplyCommand}"/>

        <Button Grid.Row="5" Grid.Column="0" Content="4" Command="{Binding AppendDigitCommand}" CommandParameter="4"/>
        <Button Grid.Row="5" Grid.Column="1" Content="5" Command="{Binding AppendDigitCommand}" CommandParameter="5"/>
        <Button Grid.Row="5" Grid.Column="2" Content="6" Command="{Binding AppendDigitCommand}" CommandParameter="6"/>
        <Button Grid.Row="5" Grid.Column="3" Content="-" Command="{Binding SubtractCommand}"/>

        <Button Grid.Row="6" Grid.Column="0" Content="1" Command="{Binding AppendDigitCommand}" CommandParameter="1"/>
        <Button Grid.Row="6" Grid.Column="1" Content="2" Command="{Binding AppendDigitCommand}" CommandParameter="2"/>
        <Button Grid.Row="6" Grid.Column="2" Content="3" Command="{Binding AppendDigitCommand}" CommandParameter="3"/>
        <Button Grid.Row="6" Grid.Column="3" Content="+" Command="{Binding AdditionCommand}"/>

        <Button Grid.Row="7" Grid.Column="0" Content="+/-" Command="{Binding NegativePositiveCommand}"/>
        <Button Grid.Row="7" Grid.Column="1" Content="0" Command="{Binding AppendDigitCommand}" CommandParameter="0"/>
        <Button Grid.Row="7" Grid.Column="2" Content="." Command="{Binding DecimalCommand}"/>
        <Button Grid.Row="7" Grid.Column="3" Content="=" Command="{Binding ResultCommand}"/>
    </Grid>
</Window>
