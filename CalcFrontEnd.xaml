<Window x:Class="Calculator.Form1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Calculator"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Foreground="{DynamicResource Theme_TextBrush}" Height="511">

    <Grid Background="White" Width="556">
        <Border BorderBrush="Black" BorderThickness="1.5" CornerRadius="3"  Margin="32,32,32,384">
            <TextBlock x:Name="viewWindow" Text="" FontSize="34" Margin="0,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="469" Height="80" Padding="10,20,0,0" />
        </Border>
        <Button Content="%" Click="percentage_Click" Margin="32,168,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="32" Width="88"/>
        <Button Content="CE" Click="clear_Entry_Click" Margin="160,168,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="C" Click="clear_Click" Margin="296,168,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="⌫" Click="delete_Click" Margin="432,168,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="⅟x" Click="reciprocal_Click" Margin="32,216,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="x²" Click="exponent_Click" Margin="32,264,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="√" Click="square_Root_Click" Margin="32,312,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="÷" Click="divide_Click" Margin="32,360,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="7" Click="seven_Click" Margin="32,408,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="8" Click="eight_Click" Margin="160,216,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="9" Click="nine_Click" Margin="160,264,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="×" Click="multiply_Click" Margin="160,312,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="4" Click="four_Click" Margin="160,360,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="5" Click="five_Click" Margin="160,408,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="6" Click="six_Click" Margin="296,216,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="-" Click="minus_Click" Margin="432,216,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="1" Click="one_Click" Margin="296,264,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="2" Click="two_Click" Margin="296,312,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="3" Click="three_Click" Margin="296,360,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="+" Click="plus_Click" Margin="296,408,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="+/-" Click="negative_Positive_Click" Margin="432,264,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="0" Click="zero_Click" Margin="432,312,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="." Click="dot_Click" Margin="432,360,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
        <Button Content="=" Click="equals_Click" Margin="432,408,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="88" Height="32" />
    </Grid>
</Window>