<Window x:Class="Calculator.Form1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Calculator"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Foreground="{DynamicResource Theme_TextBrush}"
        Width="560" Height="500"
        MinWidth="300" MinHeight="450">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Viewbox Stretch="Uniform" Margin="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.3" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="White" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TODO (MVVM - Display): Remove x:Name="viewWindow" and replace Text="" with Text="{Binding DisplayText}".
             The TextBlock will then update automatically whenever DisplayText changes in the ViewModel.
             You can also remove the x:Name since code-behind will no longer reference it directly. -->
        <Border Grid.Row="0" Grid.ColumnSpan="4" BorderBrush="#FF808080" BorderThickness="1.5" CornerRadius="3">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Right" Margin="10,8">
                <TextBlock x:Name="viewWindow" Text="" FontSize="34"/>
                <!-- TODO (MVVM): Change the line above to: <TextBlock Text="{Binding DisplayText}" FontSize="34"/> -->
            </Viewbox>
        </Border>

        <!-- TODO (MVVM - Buttons): Replace every Click="..." with Command="{Binding ...Command}".
             For example:
               Click="percentage_Click"   →   Command="{Binding PercentageCommand}"
               Click="clear_Entry_Click"  →   Command="{Binding ClearEntryCommand}"
               Click="clear_Click"        →   Command="{Binding ClearCommand}"
               Click="delete_Click"       →   Command="{Binding DeleteCommand}"
             The bindings work because DataContext is set to CalculatorViewModel in the code-behind. -->
        <Button Grid.Row="2" Grid.Column="0" Content="%" Click="percentage_Click"/>
        <Button Grid.Row="2" Grid.Column="1" Content="CE" Click="clear_Entry_Click"/>
        <Button Grid.Row="2" Grid.Column="2" Content="C" Click="clear_Click"/>
        <Button Grid.Row="2" Grid.Column="3" Content="⌫" Click="delete_Click"/>

        <Button Grid.Row="3" Grid.Column="0" Content="⅟x" Click="reciprocal_Click"/>
        <Button Grid.Row="3" Grid.Column="1" Content="x²" Click="exponent_Click"/>
        <Button Grid.Row="3" Grid.Column="2" Content="√x" Click="square_Root_Click"/>
        <Button Grid.Row="3" Grid.Column="3" Content="÷" Click="divide_Click"/>

        <!-- TODO (MVVM - Digit buttons): These could all share a single AppendDigitCommand using CommandParameter.
             Example: Command="{Binding AppendDigitCommand}" CommandParameter="7"
             Then in the ViewModel, AppendDigitCommand receives the digit string as its parameter. -->
        <Button Grid.Row="4" Grid.Column="0" Content="7" Click="seven_Click"/>
        <Button Grid.Row="4" Grid.Column="1" Content="8" Click="eight_Click"/>
        <Button Grid.Row="4" Grid.Column="2" Content="9" Click="nine_Click"/>
        <Button Grid.Row="4" Grid.Column="3" Content="x" Click="multiply_Click"/>

        <Button Grid.Row="5" Grid.Column="0" Content="4" Click="four_Click"/>
        <Button Grid.Row="5" Grid.Column="1" Content="5" Click="five_Click"/>
        <Button Grid.Row="5" Grid.Column="2" Content="6" Click="six_Click"/>
        <Button Grid.Row="5" Grid.Column="3" Content="-" Click="minus_Click"/>

        <Button Grid.Row="6" Grid.Column="0" Content="1" Click="one_Click"/>
        <Button Grid.Row="6" Grid.Column="1" Content="2" Click="two_Click"/>
        <Button Grid.Row="6" Grid.Column="2" Content="3" Click="three_Click"/>
        <Button Grid.Row="6" Grid.Column="3" Content="+" Click="plus_Click"/>

        <Button Grid.Row="7" Grid.Column="0" Content="+/-" Click="negative_Positive_Click"/>
        <Button Grid.Row="7" Grid.Column="1" Content="0" Click="zero_Click"/>
        <Button Grid.Row="7" Grid.Column="2" Content="." Click="dot_Click"/>
        <Button Grid.Row="7" Grid.Column="3" Content="=" Click="equals_Click"/>
    </Grid>
</Window>
